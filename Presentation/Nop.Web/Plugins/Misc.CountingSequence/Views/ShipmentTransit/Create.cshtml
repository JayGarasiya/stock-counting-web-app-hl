@model ShipmentTransitModel

@{
    ViewBag.PageTitle = T("Plugins.Misc.CountingSequence.ShipmentTransit.AddNewShipmentTransit").Text;
    NopHtml.SetActiveMenuItemSystemName(CountingSequenceDefaults.CountingSequenceShipmentTransit);
    Layout = "_AdminLayout";
}

<form asp-controller="ShipmentTransit" asp-action="Create" method="post" id="shipment-transit-form">
    <div class="content-header clearfix">
        <h1 class="float-left">
            @T("Plugins.Misc.CountingSequence.ShipmentTransit.AddNewShipmentTransit")
            <small>
                <i class="fas fa-arrow-circle-left"></i>
                <a asp-action="List">@T("Plugins.Misc.CountingSequence.ShipmentTransit.BackToList")</a>
            </small>
        </h1>

        <div class="float-right">
            <button type="submit" name="save" class="btn btn-primary">
                <i class="far fa-floppy-disk"></i>                 
                @T("Admin.Common.Save")
            </button>
            <button type="submit" name="save-continue" class="btn btn-primary">
                <i class="far fa-floppy-disk"></i>                 
                @T("Admin.Common.SaveContinue")
            </button>
        </div>
    </div>

    @await Html.PartialAsync("~/Plugins/Misc.CountingSequence/Views/ShipmentTransit/_CreateOrUpdate.cshtml", Model)
</form>