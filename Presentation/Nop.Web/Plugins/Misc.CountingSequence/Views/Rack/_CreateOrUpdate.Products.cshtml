@model RackModel

@if (Model.Id > 0)
{
    <div class="card-body">
        @await Html.PartialAsync("Table", new DataTablesModel
        {
            Name = "rack-level-grid",
            UrlRead = new DataUrl("RackLevelList", "Rack", null),
            PrimaryKeyColumn = nameof(LevelModel.Id),
            Length = Model.RackProductSearchModel.PageSize,
            LengthMenu = Model.RackProductSearchModel.AvailablePageSizes,

            Filters = new List<FilterParameter>
            {
                new FilterParameter(nameof(LevelSearchModel.RackId), Model.Id)
            },

            ColumnCollection = new List<ColumnProperty>
            {
                new ColumnProperty(null)
                {
                    Render = new RenderChildCaret(),
                    ClassName = NopColumnClassDefaults.ChildControl
                },

                new ColumnProperty(nameof(LevelModel.Name))
                {
                    Title = T("Plugins.Misc.CountingSequence.Rack.Fields.LevelTypeId").Text,
                    ClassName = NopColumnClassDefaults.CenterAll,
                },

                new ColumnProperty(nameof(LevelModel.Id))
                {
                    Title = T("Plugins.Misc.CountingSequence.Rack.Actions").Text,
                    Render = new RenderCustom("renderLevelActions")
                }
            },

            ChildTable = new DataTablesModel
            {
                Name = "rack-product-grid",
                UrlRead = new DataUrl("RackProductList", "Rack", null),
                UrlDelete = new DataUrl("DeleteRackProduct", "Rack", null),
                IsChildTable = true,
                Paging = false,

                Filters = new List<FilterParameter>
                {
                    new FilterParameter(nameof(RackProductSearchModel.RackId), nameof(LevelModel.RackId), true),
                    new FilterParameter(nameof(RackProductSearchModel.LevelId), nameof(LevelModel.Id), true)
                },

                ColumnCollection = new List<ColumnProperty>
                {
                    new ColumnProperty(nameof(RackProductModel.ProductName))
                    {
                        Title = T("Plugins.Misc.CountingSequence.Rack.Fields.ProductId").Text,
                        ClassName =  "text-left"
                    },

                    new ColumnProperty(nameof(RackProductModel.CategoryName))
                    {
                        Title = T("Plugins.Misc.CountingSequence.Rack.Fields.CategoryName").Text,
                        ClassName =  "text-left",
                    },
                    
                    new ColumnProperty(nameof(RackProductModel.Specification))
                    {
                        Title = T("Plugins.Misc.CountingSequence.Rack.Fields.Specification").Text,
                        ClassName =  "text-left",
                    },

                    new ColumnProperty(nameof(RackProductModel.ProductPositionName))
                    {
                        Title = T("Plugins.Misc.CountingSequence.Rack.Fields.RackProductPositionId").Text,
                        ClassName =  "text-left",
                    },
                    new ColumnProperty(nameof(RackProductModel.Id))
                    {
                        Title = T("Admin.Common.Delete").Text,
                        Render = new RenderButtonRemove("Delete")
                    }
                }
            }
        })
</div>

<div class="card-footer">
    <button type="button" id="btnRefreshRackProductLevels" style="display:none"></button>
</div>
}
else
{
    <div class="card-body">
        @T("Plugins.Misc.CountingSequence.Rack.SaveRackBeforeProduct")
    </div>
}

<script>
    var baseUrl = '@Url.Action("RackProductAddPopup", "Rack")';
    var addText = '@T("Admin.Catalog.Categories.Products.AddNew")';

    function renderLevelActions(data, type, row, meta) {

        return '<button type="button" class="btn btn-primary btn-add-product" ' +
            'data-rack="' + row.RackId + '" ' +
            'data-level="' + row.Id + '">' +
            addText +
            '</button>';
    }

    // open popup safely
    $(document).on('click', '.btn-add-product', function () {

        var rackId = $(this).data('rack');
        var levelId = $(this).data('level');

        var url = baseUrl +
            '?rackId=' + rackId +
            '&levelId=' + levelId;

        // store for refresh
        window.lastRackId = rackId;
        window.lastLevelId = levelId;

        OpenWindow(url, 800, 800, true);
    });

    $('#btnRefreshRackProductLevels').click(function () {
        var table = $('#rack-level-grid').DataTable();

        var levelId = window.lastLevelId;

        table.rows().every(function () {

            var row = this.data();

            if (row && row.Id == levelId) {

                var tr = $(this.node());

                // reload ONLY this child
                if (tr.hasClass('shown')) {
                    tr.find('td.child-control').trigger('click');
                    tr.find('td.child-control').trigger('click');
                }

                return false;
            }
        });
    });
</script>