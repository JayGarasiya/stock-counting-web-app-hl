@model BackOrdersSearchModel

@{
    Layout = "_AdminLayout";
    NopHtml.SetActiveMenuItemSystemName(CountingSequenceDefaults.CountingSequnceBackOrders);
}
@{
    const string hideSearchBlockAttributeName = "ProductListPage.HideSearchBlock";
    var hideSearchBlock = await genericAttributeService.GetAttributeAsync<bool>(await workContext.GetCurrentCustomerAsync(), hideSearchBlockAttributeName);
}

@Html.AntiForgeryToken()
<div class="content-header clearfix">
    <h1 class="float-left"> @T("Plugins.Misc.CountingSequence.BackOrder")</h1>
    <div class="float-right">
        <button type="button" class="btn btn-primary" onclick="openCreatePopup()">
            <i class="fas fa-plus"></i> @T("Plugins.Misc.CountingSequence.BackOrder.CreateBackOrder")
        </button>
    </div>
</div>
<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <div class="cards-group">
                <div class="card card-default card-search">
                    <div class="card-body">
                        <div class="row search-row @(!hideSearchBlock ? "opened" : "")" data-hideAttribute="@hideSearchBlockAttributeName">
                            <div class="search-text">@T("Admin.Common.Search")</div>
                            <div class="icon-search"><i class="fas fa-magnifying-glass" aria-hidden="true"></i></div>
                            <div class="icon-collapse"><i class="far fa-angle-@(!hideSearchBlock ? "up" : "down")" aria-hidden="true"></i></div>
                        </div>
                        <div class="search-body @(hideSearchBlock ? "closed" : "")">
                            <div class="row">
                                <div class="col-md-5">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchRefrenceNumber" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-editor asp-for="SearchRefrenceNumber" />
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchChennelId" />
                                        </div>
                                        <div class="col-md-8">
                                            <input type="text" id="search-channel-name" autocomplete="off" class="form-control" />
                                            <span id="search-channel-friendly-name"></span>
                                            <button type="button" id="search-channel-clear" class="btn bg-gray" style="display: none; margin-top: 5px;">@T("Admin.Common.Clear")</button>
                                            <input asp-for="SearchChennelId" autocomplete="off" style="display: none;" />
                                            <script>
                                                $(function() {
                                                    $('#search-channel-name').autocomplete({
                                                        delay: 500,
                                                        minLength: 3,
                                                        source: '@Url.Action("SearchChannelAutoComplete", "Channel")',
                                                        select: function(event, ui) {
                                                            $('#@Html.IdFor(model => model.SearchChennelId)').val(ui.item.channelid);
                                                            $('#search-channel-friendly-name').text(ui.item.label);

                                                            $('#search-channel-clear').show();
                                                            return false;
                                                        }
                                                    });

                                                    //remove button
                                                    $('#search-channel-clear').click(function() {
                                                        $('#@Html.IdFor(model => model.SearchChennelId)').val('0');
                                                        $('#search-channel-friendly-name').text('');
                                                        $('#search-channel-clear').hide();
                                                        return false;
                                                    });
                                                });
                                            </script>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchSatus" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-select asp-for="SearchSatus" asp-items="Model.AvailableStatus" />
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchProductId" />
                                        </div>
                                        <div class="col-md-8">
                                            <input type="text" id="search-product-name" autocomplete="off" class="form-control" />
                                            <span id="search-product-friendly-name"></span>
                                            <button type="button" id="search-product-clear" class="btn bg-gray" style="display: none; margin-top: 5px;">@T("Admin.Common.Clear")</button>
                                            <input asp-for="SearchProductId" autocomplete="off" style="display: none;" />
                                            <script>
                                                $(function() {
                                                    $('#search-product-name').autocomplete({
                                                        delay: 500,
                                                        minLength: 3,
                                                        source: '@Url.Action("SearchProductSku", "Rack")',
                                                        select: function(event, ui) {
                                                            $('#@Html.IdFor(model => model.SearchProductId)').val(ui.item.productid);
                                                            $('#search-product-friendly-name').text(ui.item.label);

                                                            $('#search-product-clear').show();
                                                            return false;
                                                        }
                                                    });

                                                    //remove button
                                                    $('#search-product-clear').click(function() {
                                                        $('#@Html.IdFor(model => model.SearchProductId)').val('0');
                                                        $('#search-product-friendly-name').text('');
                                                        $('#search-product-clear').hide();
                                                        return false;
                                                    });
                                                });
                                            </script>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-7">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="MinQuantity" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-editor asp-for="MinQuantity" />
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="MaxQuantity" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-editor asp-for="MaxQuantity" />
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="StartDate" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-editor asp-for="StartDate" />
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="EndDate" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-editor asp-for="EndDate" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="text-center col-12">
                                    <button type="button" id="search-backOrders" class="btn btn-primary btn-search">
                                        <i class="fas fa-magnifying-glass"></i>
                                        @T("Admin.Common.Search")
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card">
                    <div class="card-body">
                    @await Html.PartialAsync("Table", new DataTablesModel
                    {
                        Name = "backorder-grid",
                        UrlRead = new DataUrl("BackOrdersList", "BackOrders", null),
                        SearchButtonId = "search-backOrders",
                        PrimaryKeyColumn = nameof(BackOrdersModel.Id),
                        Length = Model.PageSize,
                        LengthMenu = Model.AvailablePageSizes,
                         Filters = new List<FilterParameter>
                         {
                             new FilterParameter(nameof(Model.SearchRefrenceNumber)),
                             new FilterParameter(nameof(Model.SearchSatus)),
                             new FilterParameter(nameof(Model.SearchChennelId)),
                             new FilterParameter(nameof(Model.SearchProductId)),
                             new FilterParameter(nameof(Model.MinQuantity)),
                             new FilterParameter(nameof(Model.MaxQuantity)),
                             new FilterParameter(nameof(Model.StartDate)),
                             new FilterParameter(nameof(Model.EndDate))

                         },
                        ColumnCollection = new List<ColumnProperty>
                        {
                           new ColumnProperty(nameof(BackOrdersModel.ReferenceNo))
                           {
                                Title = T("Plugins.Misc.CountingSequence.BackOrder.Fields.ReferenceNo").Text,
                                ClassName = NopColumnClassDefaults.CenterAll
                           },   
                            new ColumnProperty(nameof(BackOrdersModel.ChannelName))
                            {   
                                Title = T("Plugins.Misc.CountingSequence.BackOrder.Fields.ChannelId").Text,
                                ClassName = NopColumnClassDefaults.CenterAll
                            },  
                             new ColumnProperty(nameof(BackOrdersModel.ProductName))
                             {  
                                 Title = T("Plugins.Misc.CountingSequence.BackOrder.Fields.ProductId").Text,
                                 ClassName = NopColumnClassDefaults.CenterAll
                             }, 
                             new ColumnProperty(nameof(BackOrdersModel.Quantity))
                             {  
                                  Title = T("Plugins.Misc.CountingSequence.BackOrder.Fields.Quantity").Text,
                                  ClassName = NopColumnClassDefaults.CenterAll
                             }, 
                             new ColumnProperty(nameof(BackOrdersModel.Statuss))
                             {  
                                  Title = T("Plugins.Misc.CountingSequence.BackOrder.Fields.Status").Text,
                                  ClassName = NopColumnClassDefaults.CenterAll
                             }, 
                             new ColumnProperty(nameof(BackOrdersModel.OrderDate))
                             {  
                                  Title = T("Plugins.Misc.CountingSequence.BackOrder.Fields.OrderDate").Text,
                                  ClassName = NopColumnClassDefaults.CenterAll,
                                  Render = new RenderDate { Format = "DD-MM-YYYY" }
                             },
                             new ColumnProperty(nameof(BackOrdersModel.Id))
                             {
                                  Title = T("Admin.Common.Edit").Text,
                                  Width = "100",
                                  ClassName = NopColumnClassDefaults.Button,
                                  Render = new RenderCustom("renderEditButton")
                             },
                             new ColumnProperty(nameof(BackOrdersModel.Id))
                             {
                                  Title = T("Admin.Common.Delete").Text,
                                  Width = "100",
                                  ClassName = NopColumnClassDefaults.Button,
                                  Render = new RenderCustom("renderDeleteButton")
                             }
                        },
                    })
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="backOrdersModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" id="backOrderModalContent">
        </div>
    </div>
</div>

<script>

    function renderEditButton(data, type, row, meta) {
        if (!row.CanEditDelete)
            return '';
        return '<button type="button" class="btn btn-default" onclick="openEditPopup(' + data + ')"><i class="fas fa-pencil-alt"></i> Edit</button>';
    }

    function renderDeleteButton(data, type, row, meta) {
        if (!row.CanEditDelete)
            return '';
        return '<button type="button" class="btn btn-danger" onclick="deleteBackOrders(' + data + ')"><i class="far fa-trash-alt"></i> Delete</button>';
    }

    function deleteBackOrders(id) {
          $.ajax({
              type: "POST",
              url: '@Url.Action("Delete", "BackOrders")',
              data: {
                  id: id,
                  __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
              },
              success: function (response) {
                  if (response.success) {
                   let htmlcode = '<div class="alert alert-success alert-dismissable"><button class="close" data-dismiss="alert" aria-hidden="true">×</button><span> ' + response.message + ' </span></div>'
                   $('#admin-notifications').append(htmlcode);
                   updateTable('#backorder-grid');
                  } else {
                      alert('Delete failed');
                  }
              },
              error: function () {
                  alert('Error while deleting');
              }
          });
     }

    function openCreatePopup() {
        $.get('@Url.Action("Create", "BackOrders")', function (data) {
            $('#backOrderModalContent').html(data);
            $('#backOrdersModal').modal('show');
        });
    }

    function openEditPopup(id) {
        $.get('@Url.Action("Edit", "BackOrders")?id=' + id, function (data) {
            $('#backOrderModalContent').html(data);
            $('#backOrdersModal').modal('show');
        });
    }

    function saveBackOrders(form) {
        $.post(form.action, $(form).serialize(), function (result) {
            if (result.success) {
                $('#backOrdersModal').modal('hide');
                let htmlcode = '<div class="alert alert-success alert-dismissable"><button class="close" data-dismiss="alert" aria-hidden="true">×</button><span> ' + result.message + ' </span></div>'
                   $('#admin-notifications').append(htmlcode);
                   updateTable('#backorder-grid');
            } else {
                $('#backOrderModalContent').html(result);
            }
        });
        return false;
     }

</script>