@model PalletModel

@{
    ViewBag.PageTitle = T("Plugins.Misc.CountingSequence.Pallet.EditPallet").Text;
    NopHtml.SetActiveMenuItemSystemName(CountingSequenceDefaults.CountingSequencePallet);
    Layout = "_AdminLayout";

}

<form asp-controller="Pallet" asp-action="Edit" method="post" id="pallet-form" name="pallet-form">
    <div class="content-header clearfix">
        <h1 class="float-left">
            @T("Plugins.Misc.CountingSequence.Pallet.EditPallet") - @Model.Name
            <small>
                <i class="fas fa-arrow-circle-left"></i>
                <a asp-action="List"> @T("Plugins.Misc.CountingSequence.Pallet.BackToList")</a>
            </small>
        </h1>

        <div class="float-right">
            <button type="submit" name="save" class="btn btn-primary">@T("Admin.Common.Save")</button>
            <button type="submit" name="save-continue" class="btn btn-primary">@T("Admin.Common.SaveContinue")</button>

            <span id="pallet-delete" class="btn btn-danger">
                <i class="far fa-trash-can"></i>
                @T("Admin.Common.Delete")
            </span>
        </div>
    </div>

    @await Html.PartialAsync("~/Plugins/Misc.CountingSequence/Views/Pallet/_CreateOrUpdate.cshtml", Model)
</form>

<nop-delete-confirmation asp-model-id="@Model.Id" asp-button-id="pallet-delete" />