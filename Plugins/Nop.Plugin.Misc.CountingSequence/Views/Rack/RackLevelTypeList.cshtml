@model RackLevelTypeSearchModel

@{
    Layout = "_AdminLayout";
    NopHtml.SetActiveMenuItemSystemName(CountingSequenceDefaults.CountingSequenceRackLevelType);
}

@{
    const string hideSearchBlockAttributeName = "ProductListPage.HideSearchBlock";
    var hideSearchBlock = await genericAttributeService.GetAttributeAsync<bool>(await workContext.GetCurrentCustomerAsync(), hideSearchBlockAttributeName);
}

@Html.AntiForgeryToken()
<div class="content-header clearfix">
    <h1 class="float-left"> @T("Plugins.Misc.CountingSequence.RackLevelType")</h1>
    <div class="float-right">
        <button type="button" class="btn btn-primary" onclick="openCreatePopup()">
            <i class="fas fa-plus"></i> @T("Plugins.Misc.CountingSequence.RackLevelType.CreateRackLevel")
        </button>
    </div>
</div>
<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <div class="cards-group">
                <div class="card card-default card-search">
                    <div class="card-body">
                        <div class="row search-row @(!hideSearchBlock ? "opened" : "")" data-hideAttribute="@hideSearchBlockAttributeName">
                            <div class="search-text">@T("Admin.Common.Search")</div>
                            <div class="icon-search"><i class="fas fa-magnifying-glass" aria-hidden="true"></i></div>
                            <div class="icon-collapse"><i class="far fa-angle-@(!hideSearchBlock ? "up" : "down")" aria-hidden="true"></i></div>
                        </div>
                        <div class="search-body @(hideSearchBlock ? "closed" : "")">
                            <div class="row">
                                <div class="col-md-5">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchRackLevelName" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-editor asp-for="SearchRackLevelName" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-7">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchFunctionTypeId" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-select asp-for="SearchFunctionTypeId" asp-items="Model.AvailableFunctionType" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="text-center col-12">
                                    <button type="button" id="search-rackleveltype" class="btn btn-primary btn-search">
                                        <i class="fas fa-magnifying-glass"></i>
                                        @T("Admin.Common.Search")
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card">
                    <div class="card-body">
                    @await Html.PartialAsync("Table", new DataTablesModel
                    {
                        Name = "rackleveltype-grid",
                        UrlRead = new DataUrl("RackLevelTypeList", "Rack", null),
                        SearchButtonId = "search-rackleveltype",
                        PrimaryKeyColumn = nameof(RackLevelTypeModel.Id),
                        Length = Model.PageSize,
                        LengthMenu = Model.AvailablePageSizes,
                         Filters = new List<FilterParameter>
                         {
                             new FilterParameter(nameof(Model.SearchRackLevelName)),
                             new FilterParameter(nameof(Model.SearchFunctionTypeId)),
                         },
                        ColumnCollection = new List<ColumnProperty>
                        {
                           new ColumnProperty(nameof(RackLevelTypeModel.Name))
                           {
                                Title = T("Plugins.Misc.CountingSequence.Fields.RackLevelType.Name").Text,
                                ClassName = NopColumnClassDefaults.CenterAll
                           },

                           new ColumnProperty(nameof(RackLevelTypeModel.FunctionTypeName))
                           {
                               Title = T("Plugins.Misc.CountingSequence.Fields.RackLevelType.RackLevelTypeId").Text,
                               ClassName = NopColumnClassDefaults.CenterAll
                           },

                           new ColumnProperty(nameof(RackLevelTypeModel.DisplayOrder))
                           {
                               Title = T("Plugins.Misc.CountingSequence.Fields.RackLevelType.DisplayOrder").Text,
                               ClassName = NopColumnClassDefaults.CenterAll
                           },

                           new ColumnProperty(nameof(RackLevelTypeModel.IsVisible))
                           {
                               Title = T("Plugins.Misc.CountingSequence.Fields.RackLevelType.IsVisible").Text,
                               ClassName = NopColumnClassDefaults.CenterAll,
                                Render = new RenderBoolean()

                           },
                           
                           new ColumnProperty(nameof(RackLevelTypeModel.Id))
                           {
                               Title = T("Plugins.Misc.CountingSequence.Fields.RackLevelType.Actions").Text,
                               ClassName = NopColumnClassDefaults.Button,
                               Render = new RenderCustom("renderActions")
                           }
                        },
                    })
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="rackLevelTypeModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" id="rackLeveltypeModalContent">
        </div>
    </div>
</div>

<script>

    function renderActions(data, type, row, meta) {
         return `
            <button class="btn btn-sm btn-warning mr-1" onclick="openEditPopup(${data})"> Edit </button>
            <button class="btn btn-sm btn-danger" onclick="deleteRackLevelType(${data})"> Delete </button>
         `;
     }

     function deleteRackLevelType(id) {
          if (!confirm('Are you sure you want to delete this rack level?'))
              return;
          $.ajax({
              type: "POST",
              url: '@Url.Action("RackLevelDelete", "Rack")',
              data: {
                  id: id,
                  __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
              },
              success: function (response) {
                  if (response.success) {
                   let htmlcode = '<div class="alert alert-success alert-dismissable"><button class="close" data-dismiss="alert" aria-hidden="true">×</button><span> ' + response.message + ' </span></div>'
                   $('#admin-notifications').append(htmlcode);
                   updateTable('#rackleveltype-grid');
                  } else {
                      alert('Delete failed');
                  }
              },
              error: function () {
                  alert('Error while deleting');
              }
          });
     }

    function openCreatePopup() {
        $.get('@Url.Action("RackLevelCreate", "Rack")', function (data) {
            $('#rackLeveltypeModalContent').html(data);
            $('#rackLevelTypeModal').modal('show');
        });
    }

    function openEditPopup(id) {
        $.get('@Url.Action("RackLevelEdit", "Rack")?id=' + id, function (data) {
            $('#rackLeveltypeModalContent').html(data);
            $('#rackLevelTypeModal').modal('show');
        });
    }

    function saveRackLevelType(form) {
        $.post(form.action, $(form).serialize(), function (result) {
            if (result.success) {
                $('#rackLevelTypeModal').modal('hide');
                let htmlcode = '<div class="alert alert-success alert-dismissable"><button class="close" data-dismiss="alert" aria-hidden="true">×</button><span> ' + result.message + ' </span></div>'
                   $('#admin-notifications').append(htmlcode);
                   updateTable('#rackleveltype-grid');
            } else {
                $('#rackLeveltypeModalContent').html(result);
            }
        });
        return false;
     }

</script>