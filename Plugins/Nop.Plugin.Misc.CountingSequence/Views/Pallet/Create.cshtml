@model PalletModel

@{
    ViewBag.PageTitle = T("Plugins.Misc.CountingSequence.Pallet.AddNewPallet").Text;
    NopHtml.SetActiveMenuItemSystemName(CountingSequenceDefaults.CountingSequencePallet);
    Layout = "_AdminLayout";
    const string hideProductsBlockAttributeName = "PalletPage.HideProducts";
}

<form asp-controller="Pallet" asp-action="Create" method="post" id="pallet-form">
    <div class="content-header clearfix">
        <h1 class="float-left">
            @T("Plugins.Misc.CountingSequence.Pallet.AddNewPallet")
            <small>
                <i class="fas fa-arrow-circle-left"></i>
                <a asp-action="List">@T("Plugins.Misc.CountingSequence.Pallet.BackToList")</a>
            </small>
        </h1>

        <div class="float-right">
            <button type="submit" name="save" class="btn btn-primary">
                <i class="far fa-floppy-disk"></i>
                @T("Admin.Common.Save")
            </button>
            <button type="submit" name="save-continue" class="btn btn-primary">
                <i class="far fa-floppy-disk"></i>
                @T("Admin.Common.SaveContinue")
            </button>
        </div>
    </div>

    @await Html.PartialAsync("~/Plugins/Misc.CountingSequence/Views/Pallet/_CreateOrUpdate.cshtml", Model)

</form>

