@model PalletModel

@if (Model.Id > 0)
{
    <div class="card-body">

        @await Html.PartialAsync("Table", new DataTablesModel
        {
            Name = "pallet-product-grid",

            UrlRead = new DataUrl("PalletProductList", "Pallet", new RouteValueDictionary { [nameof(Model.PalletProductSearchModel.PalletId)] = Model.PalletProductSearchModel.PalletId }),
            UrlDelete = new DataUrl("DeletePalletProduct", "Pallet", null),
            Length = Model.PalletProductSearchModel.PageSize,
            LengthMenu = Model.PalletProductSearchModel.AvailablePageSizes,
            

            Filters = new List<FilterParameter>
            {
                new FilterParameter(nameof(PalletProductSearchModel.PalletId), Model.Id)
            },

            ColumnCollection = new List<ColumnProperty>
            {
                new ColumnProperty(nameof(PalletProductModel.ProductName))
                {
                    Title = T("Plugins.Misc.CountingSequence.Fields.Pallet.ProductId").Text,
                    ClassName =  "text-left",
                },

                new ColumnProperty(nameof(PalletProductModel.CategoryName))
                {
                    Title = T("Plugins.Misc.CountingSequence.Fields.Pallet.CategoryName").Text,
                    ClassName =  "text-left",
                },
                
                new ColumnProperty(nameof(PalletProductModel.Specification))
                {
                    Title = T("Plugins.Misc.CountingSequence.Fields.Pallet.Specification").Text,
                    ClassName =  "text-left",
                },

                new ColumnProperty(nameof(PalletProductModel.Id))
                {
                    Title = T("Admin.Common.Delete").Text,
                    Width = "100",
                    ClassName = NopColumnClassDefaults.Button,
                    Render = new RenderButtonRemove(T("Admin.Common.Delete").Text)
                }
            }
        })
    </div>

    

<div class="card-footer">
    <button type="submit" id="btnAddNew"
            onclick="javascript:OpenWindow('@(Url.Action("PalletProductAddPopup", "Pallet", new { palletId = Model.Id, btnId = "btnRefreshProducts", formId = "pallet-form" }))', 800, 800, true); return false;"
            class="btn btn-primary">
        @T("Admin.Common.AddNew")
    </button>
    <button type="submit" id="btnRefreshProducts" style="display: none"></button>
    <script>
        $(function() {
            $('#btnRefreshProducts').click(function () {
                //refresh grid
                updateTable('#pallet-product-grid');

                //return false to don't reload a page
                return false;
            });
        });
    </script>
</div>
}
else
{
    <div class="card-body">
        @T("Plugins.Misc.CountingSequence.Pallet.SavePalletBeforeProduct")
    </div>
}

