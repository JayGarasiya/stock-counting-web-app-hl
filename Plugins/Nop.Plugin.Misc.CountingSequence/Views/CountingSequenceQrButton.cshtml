@model Nop.Web.Areas.Admin.Models.Catalog.ProductModel

<button type="button" id="generateQrBtn" class="btn btn-warning">
    @T("Plugins.Misc.CountingSequence.Product.QRCode")
</button>

<script>
    $(document).ready(function () {
        $('#generateQrBtn').click(function () {
            var productId = $('#Id').val();
            var token = $('input[name="__RequestVerificationToken"]').val();

            $.ajax({
                url: '/Admin/QRGenerator/Generate',
                type: 'POST',
                data: {
                    productId: productId,
                    __RequestVerificationToken: token
                },
                success: function (response) {
                    if (response.success) {
                        let htmlcode = '<div class="alert alert-success alert-dismissable">' + '<button class="close" data-dismiss="alert" aria-hidden="true">×</button>' + '<span>' + response.message + '</span>' + '</div>';
                        $('#admin-notifications').append(htmlcode);
                        updateTable('#productpictures-grid');
                    }
                    else {
                        let htmlcode = '<div class="alert alert-danger alert-dismissable">' + '<button class="close" data-dismiss="alert" aria-hidden="true">×</button>' + '<span>' + response.message + '</span>' + '</div>';
                        $('#admin-notifications').append(htmlcode);
                    }
                },
                error: function () {
                    let htmlcode = '<div class="alert alert-danger alert-dismissable">' + '<button class="close" data-dismiss="alert" aria-hidden="true">×</button>' + '<span>Error generating QR</span>' + '</div>';
                    $('#admin-notifications').append(htmlcode);
                }
            });
        });
    });
</script>