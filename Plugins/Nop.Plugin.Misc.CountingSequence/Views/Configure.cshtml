@model ConfigurationModel

@{
    Layout = "_ConfigurePlugin";
}

@await Component.InvokeAsync(typeof(StoreScopeConfigurationViewComponent))
<form asp-controller="CountingSequence" asp-action="Configure" method="post">
    <section class="content">
        <div class="container-fluid">
            <div class="cards-group">
                <div class="card card-default">
                    <div class="card-header">
                        @T("Plugins.Misc.CountingSequence.Settings")
                    </div>
                    <div class="card-body">
                        <div class="form-group row">
                            <div class="col-md-3">
                                <nop-override-store-checkbox asp-for="Enabled_OverrideForStore" asp-input="Enabled" asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                                <nop-label asp-for="Enabled" />
                            </div>
                            <div class="col-md-9">
                                <nop-editor asp-for="Enabled" />
                                <span asp-validation-for="Enabled"></span>
                            </div>
                        </div>

                        <div class="form-group row">
                            <div class="col-md-3">
                                <nop-override-store-checkbox asp-for="PalletCountingOrder_OverrideForStore" asp-input="PalletCountingOrder" asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                                <nop-label asp-for="PalletCountingOrder" />
                            </div>
                            <div class="col-md-9">
                                <nop-select asp-for="PalletCountingOrder" asp-items="Model.AvailablePalletCountingOrder" />
                                <span asp-validation-for="PalletCountingOrder"></span>
                            </div>
                        </div>

                        <div class="form-group row">
                            <div class="col-md-3">
                                <nop-override-store-checkbox asp-for="SaleTypeOrder_OverrideForStore" asp-input="SaleTypeOrder" asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                                <nop-label asp-for="SaleTypeOrder" />
                            </div>
                            <div class="col-md-9">
                                <nop-select asp-for="SaleTypeOrder" asp-items="Model.AvailableSaleOrder" />
                                <span asp-validation-for="SaleTypeOrder"></span>
                            </div>
                        </div>

                        <div class="form-group row">
                            <div class="col-md-3">
                                <nop-override-store-checkbox asp-for="Level_OverrideForStore" asp-input="Level" asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                                <nop-label asp-for="Level" />
                            </div>
                            <div class="col-md-9">
                                <nop-select asp-for="Level" asp-items="Model.AvailableLevels" />
                                <span asp-validation-for="Level"></span>
                            </div>
                        </div>

                        <div class="form-group row">
                            <div class="col-md-3">
                                <nop-override-store-checkbox asp-for="Position_OverrideForStore" asp-input="Position" asp-store-scope="@Model.ActiveStoreScopeConfiguration" />
                                <nop-label asp-for="Position" />
                            </div>
                            <div class="col-md-9">
                                <nop-select asp-for="Position" asp-items="Model.AvailablePositions" />
                                <span asp-validation-for="Position"></span>
                            </div>
                        </div>

                        <div class="form-group row">
                            <div class="offset-md-3 col-md-9">
                                <button type="submit" class="btn btn-primary">
                                    @T("Admin.Common.Save")
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</form>