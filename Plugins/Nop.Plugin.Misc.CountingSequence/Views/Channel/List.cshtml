@model ChannelSearchModel
@{
    Layout = "_AdminLayout";
    NopHtml.SetActiveMenuItemSystemName(CountingSequenceDefaults.CountingSequenceChannel);
}
@{
    const string hideSearchBlockAttributeName = "ChannelPage.HideSearchBlock";
    var hideSearchBlock = await genericAttributeService.GetAttributeAsync<bool>(await workContext.GetCurrentCustomerAsync(), hideSearchBlockAttributeName);
}

<div class="content-header clearfix">
    <h1 class="float-left">
        @T("Plugins.Misc.CountingSequence.Channel")
    </h1>
    <div class="float-right">
        <button type="button" class="btn btn-primary" onclick="openCreatePopup()">
            <i class="fas fa-plus"></i>
            @T("Plugins.Misc.CountingSequence.CreateChannel")
        </button>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <div class="cards-group">
                <div class="card card-default card-search">
                    <div class="card-body">
                        <div class="row search-row @(!hideSearchBlock ? "opened" : "")" data-hideAttribute="@hideSearchBlockAttributeName">
                            <div class="search-text">@T("Admin.Common.Search")</div>
                            <div class="icon-search"><i class="fas fa-magnifying-glass" aria-hidden="true"></i></div>
                            <div class="icon-collapse"><i class="far fa-angle-@(!hideSearchBlock ? "up" : "down")" aria-hidden="true"></i></div>
                        </div>

                        <div class="search-body @(hideSearchBlock ? "closed" : "")">
                            <div class="row">
                                <div class="col-md-5">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchChannelName" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-editor asp-for="SearchChannelName" />
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchChannelTypeId" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-select asp-for="SearchChannelTypeId" asp-items="Model.AvailableChannelTypes" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-7">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchVisibleId" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-select asp-for="SearchVisibleId" asp-items="Model.AvailableVisibleOptions" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="text-center col-12">
                                    <button type="button" id="search-channel" class="btn btn-primary btn-search">
                                        <i class="fas fa-magnifying-glass"></i>
                                        @T("Admin.Common.Search")
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card">
                <div class="card-body">
                    @await Html.PartialAsync("Table", new DataTablesModel
                    {
                        Name = "channel-grid",
                        UrlRead = new DataUrl("List", "Channel", null),
                        SearchButtonId = "search-channel",
                        Length = Model.PageSize,
                        LengthMenu = Model.AvailablePageSizes,
                        Filters = new List<FilterParameter>
                        {
                            new FilterParameter(nameof(Model.SearchChannelName)),
                            new FilterParameter(nameof(Model.SearchVisibleId)),
                            new FilterParameter(nameof(Model.SearchChannelTypeId)),
                        },

                        ColumnCollection = new List<ColumnProperty>
                        {
                            new ColumnProperty(nameof(ChannelModel.Name))
                            {
                                Title = T("Plugins.Misc.CountingSequence.Channel.Fields.Name").Text,
                            },
                            new ColumnProperty(nameof(ChannelModel.ChannelTypeName))
                            {
                                Title = T("Plugins.Misc.CountingSequence.Channel.Fields.ChannelId").Text,
                            },
                            new ColumnProperty(nameof(ChannelModel.Description))
                            {
                                Title = T("Plugins.Misc.CountingSequence.Channel.Fields.Description").Text,
                            },
                            new ColumnProperty(nameof(ChannelModel.DisplayOrder))
                            {
                                Title = T("Plugins.Misc.CountingSequence.Channel.Fields.DisplayOrder").Text,
                                ClassName = NopColumnClassDefaults.CenterAll,
                            },
                            new ColumnProperty(nameof(ChannelModel.Visible))
                            {
                                Title = T("Plugins.Misc.CountingSequence.Channel.Fields.Visible").Text,
                                ClassName = NopColumnClassDefaults.CenterAll,
                                Render = new RenderBoolean()
                            },
                            new ColumnProperty(nameof(ChannelModel.Id))
                            {
                                Title = "Actions",
                                Width = "150",
                                ClassName = NopColumnClassDefaults.Button,
                                Render = new RenderCustom("renderActions")
                            }
                        }
                    })
                </div>
            </div>
        </div>
    </div>
</section>


<div class="modal fade" id="channelModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" id="channelModalContent">
        </div>
    </div>
</div>

<script>
     function renderActions(data, type, row, meta) {
         return `
             <button class="btn btn-sm btn-warning mr-1" onclick="openEditPopup(${data})"> Edit </button>
             <button class="btn btn-sm btn-danger" onclick="deleteChannel(${data})"> Delete </button>
         `;
     }

    function deleteChannel(id) {
          if (!confirm('Are you sure you want to delete this channel?'))
              return;
          $.ajax({
              type: "POST",
              url: '@Url.Action("Delete", "Channel")',
              data: {
                  id: id,
                  __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
              },
              success: function (response) {
                  if (response.success) {
                    let htmlcode = '<div class="alert alert-success alert-dismissable"><button class="close" data-dismiss="alert" aria-hidden="true">×</button><span>' + response.message + '</span></div>'
                    $('#admin-notifications').append(htmlcode);
                    updateTable('#channel-grid');
                  } else {
                      alert('Delete failed');
                  }
              },
              error: function () {
                  alert('Error while deleting');
              }
          });
    }

    function openCreatePopup() {
        $.get('@Url.Action("Create", "Channel")', function (data) {
            $('#channelModalContent').html(data);
            $('#channelModal').modal('show');
        });
    }

    function openEditPopup(id) {
        $.get('@Url.Action("Edit", "Channel")?id=' + id, function (data) {
            $('#channelModalContent').html(data);
            $('#channelModal').modal('show');
        });
    }

    function saveChannel(form) {
        $.post(form.action, $(form).serialize(), function (result) {
            if (result.success) {
                $('#channelModal').modal('hide');
                let htmlcode = '<div class="alert alert-success alert-dismissable"><button class="close" data-dismiss="alert" aria-hidden="true">×</button><span> ' + result.message + ' </span></div>'
                $('#admin-notifications').append(htmlcode);
                updateTable('#channel-grid');
            } else {
                $('#channelModalContent').html(result);
            }
        });
        return false;
    }
</script>


